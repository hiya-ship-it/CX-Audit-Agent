# Copy this to .env and fill in your values
OPENAI_API_KEY=sk-your-openai-key-here

# Target website
TARGET_URL=https://www.bajajfinserv.in

# Agent settings
MAX_STEPS=25
MAX_RETRIES=3
HEADED=true
SLOW_MO=600

# Browser viewport
VIEWPORT_WIDTH=1366
VIEWPORT_HEIGHT=768

# OpenAI model
OPENAI_MODEL=gpt-4.1
OPENAI_TIMEOUT_SECONDS=120

# Behaviour flags
HUMAN_LIKE=true                  # random delays, hover-before-click, smooth scrolls
DEBUG_MODE=false                 # verbose logs, 10-step cap, SLOW_MO=1200
