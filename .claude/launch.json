{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["server.py", "--port", "5000"],
      "port": 5000
    },
    {
      "name": "Dashboard Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "dashboard"],
      "port": 8765,
      "autoPort": false
    },
    {
      "name": "Architecture",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8766"],
      "port": 8766,
      "autoPort": false
    },
    {
      "name": "CX Audit Agent (all personas)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-X", "utf8", "main.py"],
      "port": 0
    },
    {
      "name": "CX Audit Agent (debug — first persona only)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-X", "utf8", "main.py", "--debug"],
      "port": 0
    },
    {
      "name": "CX Audit Agent (headless)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-X", "utf8", "main.py", "--no-headed"],
      "port": 0
    }
  ]
}
